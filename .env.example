# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# --- SEC EDGAR ---
# The SEC requires a descriptive User-Agent with contact info on every request.
# Format: "Sample Company Name AdminContact@example.com"
EDGAR_IDENTITY=Your Name your.email@example.com

# --- LLM: Ollama Cloud (extraction + judgment) ---
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=

# --- LLM (optional): Gemini via Vertex AI ---
# Set config/models.yaml provider->vertex to use. Needs the Vertex AI API enabled.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Neo4j (Neo4j Aura Free or Desktop) ---
# Aura: user/database are the instance id; Desktop: user=neo4j, uri=bolt://localhost:7687
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Qdrant (Qdrant Cloud or self-hosted) ---
QDRANT_URL=https://xxxx.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_TOPIC_COLLECTION=topic_embeddings
QDRANT_CLAIM_COLLECTION=claim_embeddings

# --- Observability: Langfuse Cloud (optional; tracing is a no-op if unset) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
