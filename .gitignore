# --- Secrets / local env ---
.env
# Google service-account keys (never commit)
*service-account*.json
*-*.json.key
credentials/

# --- Data (raw filings, parsed intermediate stores) ---
# data/processed/ (claims + per-document JSON) and data/raw/SYN-*.pdf are the
# pre-loaded demo dataset the Dockerfile bakes into the image (see
# api/citations.py, which reads these local files at request time, not the
# DB). They MUST be git-tracked: a Cloud Build trigger clones from git, so
# anything gitignored is silently absent from CI/CD-built images even though
# a manual `gcloud run deploy --source .` (governed by .gcloudignore, which
# reads local disk) would have included it. Only the bulky real-filing HTML
# is excluded — real citations render from the processed JSON, not the raw
# HTML, and it's regenerable via live processing.
data/raw/*.html

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / frontend ---
frontend/node_modules/
frontend/dist/
frontend/.vite/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- Claude Code local settings (keep launch.json, ignore local machine settings) ---
.claude/
